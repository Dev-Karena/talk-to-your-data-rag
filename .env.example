# ==============================================================================
# Talk to Your Data — Environment Configuration Template
# ------------------------------------------------------------------------------
# 1. Copy this file to ".env":        copy .env.example .env   (Windows)
# 2. Fill in your real keys below.
# 3. NEVER commit ".env" — it is gitignored. This ".env.example" is safe to commit.
#
# Only GROQ_API_KEY is REQUIRED (the default embedding backend is local).
# ==============================================================================


# ------------------------------------------------------------------------------
# LLM — Groq (REQUIRED)
# ------------------------------------------------------------------------------
# Get a free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Groq model used for answer generation.
# Alternatives: llama-3.1-8b-instant (faster/cheaper), openai/gpt-oss-120b.
LLM_MODEL=llama-3.3-70b-versatile

# Max tokens for the generated answer.
LLM_MAX_TOKENS=2048


# ------------------------------------------------------------------------------
# EMBEDDINGS — pluggable backend
# ------------------------------------------------------------------------------
# Which backend to use: local | voyage | openai
#   local  -> sentence-transformers, runs offline, NO API key needed (default)
#   voyage -> Voyage AI, requires VOYAGE_API_KEY
#   openai -> OpenAI, requires OPENAI_API_KEY
EMBEDDING_BACKEND=local

# Model name for the chosen backend:
#   local  -> BAAI/bge-small-en-v1.5  (modern, strong on retrieval, ~130MB)
#   voyage -> voyage-3
#   openai -> text-embedding-3-small
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Keys for the OPTIONAL API embedding backends (leave blank if using local):
VOYAGE_API_KEY=
OPENAI_API_KEY=


# ------------------------------------------------------------------------------
# CHUNKING (see README for recommended-value rationale)
# ------------------------------------------------------------------------------
# Characters per chunk. ~1000 holds a coherent paragraph while staying focused.
CHUNK_SIZE=1000

# Overlap between consecutive chunks (~10–20% of CHUNK_SIZE) to preserve context.
CHUNK_OVERLAP=150


# ------------------------------------------------------------------------------
# RETRIEVAL
# ------------------------------------------------------------------------------
# How many top chunks to retrieve per question.
TOP_K=4
# Diversify retrieval with Maximal Marginal Relevance so the final TOP_K spans
# multiple documents instead of collapsing onto the single most-similar one.
# Strongly recommended when several PDFs are indexed (improves cross-document
# questions like "compare A and B"). Set to false for pure relevance ranking.
USE_MMR=true
# Candidate pool fetched before MMR re-ranking (must be >= TOP_K to have an
# effect). Larger = more documents for MMR to diversify across. Ignored if
# USE_MMR=false.
FETCH_K=20
# MMR trade-off in [0, 1]: 1.0 = relevance only (no diversity), 0.0 = diversity
# only. 0.5 balances relevance and cross-document coverage.
MMR_LAMBDA=0.5


# ------------------------------------------------------------------------------
# VECTOR STORE (ChromaDB — local & persistent)
# ------------------------------------------------------------------------------
# Directory where the vector DB is persisted (created automatically).
CHROMA_PERSIST_DIR=./chroma_db

# Name of the Chroma collection that holds document chunks.
CHROMA_COLLECTION_NAME=talk_to_your_data


# ------------------------------------------------------------------------------
# FILE UPLOAD / SECURITY
# ------------------------------------------------------------------------------
# Directory where uploaded PDFs are stored (created automatically).
DOCUMENTS_DIR=./documents

# Maximum allowed size per uploaded file, in megabytes.
MAX_FILE_SIZE_MB=25


# ------------------------------------------------------------------------------
# LOGGING
# ------------------------------------------------------------------------------
# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Log file path (created automatically).
LOG_FILE=./app.log
