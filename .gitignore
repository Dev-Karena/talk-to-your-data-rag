# ==============================================================================
# Talk to Your Data — Git ignore rules
# ==============================================================================

# ---- Secrets (CRITICAL: never commit real keys) ------------------------------
.env
.env.*
!.env.example

# ---- Generated data / runtime artifacts --------------------------------------
# Ignore the contents of these dirs, but keep the folders themselves (.gitkeep)
# so a fresh clone has the directory layout the app expects.
chroma_db/*
!chroma_db/.gitkeep
documents/*
!documents/.gitkeep

benchmark_corpus/source_docs/

# Isolated benchmark corpus (generated by scripts/build_benchmark_corpus.py).
benchmark_chroma/*
!benchmark_chroma/.gitkeep
# Logs
*.log
logs/

# ---- Python ------------------------------------------------------------------
__pycache__/
*.pyc
.pytest_cache/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# ---- Virtual environments ----------------------------------------------------
venv/
.venv/
env/
ENV/
# Anaconda local env folders
envs/

# ---- Testing / coverage ------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/

# ---- Caches ------------------------------------------------------------------
# Hugging Face / sentence-transformers model cache (if kept inside the project)
.cache/
.huggingface/

# ---- IDE / editor ------------------------------------------------------------
.vscode/
.idea/
*.swp
*~

# Evaluation artifacts
# Evaluation artifacts
docs/
SESSION_SUMMARY.md
PROJECT_STATUS.md
reports/

docs/eval/*.json
docs/eval/*.csv
docs/eval/*.html

# ---- Claude Code (machine-local settings) ------------------------------------
.claude/

# ---- OS ----------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---- Streamlit ---------------------------------------------------------------
.streamlit/secrets.toml

models/
*.bin
*.safetensors


